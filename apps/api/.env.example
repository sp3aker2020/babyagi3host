# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/picohost

# Required: 32-byte (64 hex chars) encryption key for stored credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_hex_chars_generated_key_here_00000000000000000000

# Required: Solana treasury wallet address (your wallet that receives SOL)
TREASURY_WALLET_ADDRESS=YourSolanaWalletAddressHere

# Optional: Solana RPC URL (default: mainnet-beta)
# Recommended: Get a free Helius key at https://helius.dev
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Required: Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Optional: Docker data directory for picobot volumes
PICOBOT_DATA_ROOT=/data/picohost

# Optional: Docker socket path
DOCKER_SOCKET=/var/run/docker.sock

# Server port
PORT=4000
